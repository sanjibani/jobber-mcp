# Jobber access token — get one via OAuth2 flow at https://developer.getjobber.com/docs/
# Each app install gets its own access token. Store it securely (env, secrets manager).
JOBBER_ACCESS_TOKEN=your-oauth2-bearer-token

# Optional override (most users won't change this).
# JOBBER_BASE_URL=https://api.getjobber.com/api/graphql